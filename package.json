{
  "name": "marketing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen",
    "generate:reserved-slugs": "node scripts/generate-reserved-slugs.mjs",
    "create:success-room": "node scripts/success-room/create.mjs",
    "refresh:success-room:benefits": "node scripts/success-room/refresh-benefits.mjs",
    "add:success-room:mutual-success-plan": "node scripts/success-room/add-sections/mutual-success-plan.mjs",
    "add:success-room:initial-format": "node scripts/success-room/add-sections/initial-format.mjs",
    "add:success-room:kickoff-schedule": "node scripts/success-room/add-sections/kickoff-schedule.mjs",
    "build": "npm run generate:reserved-slugs && svelte-kit sync && vite build",
    "check": "npm run generate:reserved-slugs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "convex": "^1.42.1",
    "nodemailer": "^9.0.1",
    "phosphor-svelte": "^3.0.1",
    "svelte": "^5.0.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.1",
    "autoprefixer": "^10.4.20",
    "mdsvex": "^0.12.7",
    "postcss": "^8.4.49",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  }
}
